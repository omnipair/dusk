{
  "name": "omnipair-dusk",
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "test": "cargo test -p omnipair-v2 && cargo test -p leverage_delegate && yarn test-litesvm",
    "typecheck": "tsc --noEmit",
    "build:litesvm": "anchor build -p omnipair-v2 && anchor build -p leverage_delegate",
    "test-litesvm": "yarn build:litesvm && yarn test-litesvm:no-build",
    "test-litesvm:no-build": "mocha --require ts-node/register --extensions ts tests/v2-final-smoke.test.ts",
    "check:hygiene": "node scripts/check_repo_hygiene.js",
    "check:program-interface": "npm run check-idl-current --prefix packages/program-interface && npm run typecheck --prefix packages/program-interface",
    "test-coverage": "yarn test-litesvm",
    "coverage": "cargo tarpaulin -p omnipair-v2 --out Html --output-dir coverage --exclude-files tests",
    "coverage-report": "open coverage/index.html",
    "deploy-tokens": "ts-node --esm scripts/utils/deploy_tokens.ts",
    "address-vanity": "ts-node --esm scripts/utils/address_vanity.ts",
    "v2:create-mock-tokens": "ts-node --esm scripts/v2/create_mock_tokens.ts",
    "v2:mint-mock-tokens": "ts-node --esm scripts/v2/mint_mock_tokens.ts",
    "v2:bootstrap-market": "ts-node --esm scripts/v2/bootstrap_market.ts",
    "v2:smoke-devnet": "ts-node --esm scripts/v2/smoke_v2_devnet.ts",
    "v2:build-devnet": "anchor build -p omnipair-v2 --no-idl -- --arch v3",
    "v2:deploy-devnet": "solana program deploy target/deploy/omnipair_v2.so --program-id ${OMNIPAIR_V2_PROGRAM_KEYPAIR:-$HOME/.config/omnipair/v2-devnet/omni2-v2-program-keypair.json} --url devnet",
    "v2-fork:surfpool": "bash scripts/v2-fork-lab/start_surfpool.sh",
    "v2-fork:rpc-proxy": "node --loader ts-node/esm scripts/v2-fork-lab/rpc_proxy.ts",
    "v2-fork:api": "node --loader ts-node/esm scripts/v2-fork-lab/api.ts",
    "test-surfpool-v2": "ts-node --esm scripts/v2-fork-lab/surfpool_v2_e2e.ts",
    "surfpool-v2-e2e": "anchor build -p omnipair-v2 -- --features \"development\" && ts-node --esm scripts/v2-fork-lab/surfpool_v2_e2e_runner.ts"
  },
  "dependencies": {
    "@coral-xyz/anchor": "0.31.1",
    "@metaplex-foundation/mpl-token-metadata": "2.13.0",
    "@metaplex-foundation/umi": "0.8.2",
    "@solana/spl-token": "^0.4.0",
    "@solana/web3.js": "^1.95.0",
    "dotenv": "^16.5.0"
  },
  "devDependencies": {
    "@types/bn.js": "^5.1.0",
    "@types/chai": "^4.3.0",
    "@types/mocha": "^10.0.0",
    "@types/node": "^20.0.0",
    "chai": "^4.3.0",
    "litesvm": "^0.3.3",
    "mocha": "^10.0.0",
    "ts-mocha": "^10.0.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.0.0"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
