{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile.v2-fork-rpc",
    "watchPatterns": [
      ".dockerignore",
      "Dockerfile.v2-fork-rpc",
      "Anchor.toml",
      "Cargo.toml",
      "Cargo.lock",
      "package.json",
      "package-lock.json",
      "railway/v2-surfpool-rpc.json",
      "programs/omnipair-v2/**",
      "scripts/v2-fork-lab/start_surfpool.sh"
    ]
  },
  "deploy": {
    "startCommand": "npm run v2-fork:surfpool",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
