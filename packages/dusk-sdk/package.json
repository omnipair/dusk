{
  "name": "@omnipair/dusk-sdk",
  "version": "2.0.0",
  "description": "Omnipair Dusk (v2) SDK for program writes, RPC reads, previews, and indexer data",
  "license": "MIT",
  "author": "Omnipair <security@omnipair.fi>",
  "repository": {
    "type": "git",
    "url": "https://github.com/omnipair/dusk.git",
    "directory": "packages/dusk-sdk"
  },
  "homepage": "https://omnipair.fi",
  "keywords": [
    "solana",
    "anchor",
    "omnipair",
    "defi",
    "amm",
    "lending"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./idl": {
      "import": "./dist/idl_v2.js",
      "types": "./dist/idl_v2.d.ts"
    },
    "./idl-v2": {
      "import": "./dist/idl_v2.js",
      "types": "./dist/idl_v2.d.ts"
    },
    "./preview": {
      "import": "./dist/preview.js",
      "types": "./dist/preview.d.ts"
    },
    "./indexer": {
      "import": "./dist/indexer.js",
      "types": "./dist/indexer.d.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "prepare-idl": "node scripts/prepare.js",
    "check-idl-current": "node scripts/check-idl-current.js",
    "build": "npm run prepare-idl && tsc",
    "test": "npm run build && node --test test/*.test.mjs",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "dependencies": {
    "@coral-xyz/anchor": ">=0.30.0",
    "@solana/web3.js": "^1.95.0"
  },
  "devDependencies": {
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "@coral-xyz/anchor": ">=0.30.0"
  },
  "engines": {
    "node": ">=18"
  }
}
