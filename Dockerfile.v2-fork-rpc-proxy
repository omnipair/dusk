FROM node:20.19-bookworm-slim

WORKDIR /app

COPY package.json package-lock.json tsconfig.json ./
RUN npm ci --include=dev

COPY scripts/v2-fork-lab/rpc_proxy.ts ./scripts/v2-fork-lab/rpc_proxy.ts
RUN ./node_modules/.bin/tsc \
    --target es2022 \
    --module nodenext \
    --moduleResolution nodenext \
    --esModuleInterop \
    --skipLibCheck \
    --types node \
    --outDir dist/v2-fork-lab \
    scripts/v2-fork-lab/rpc_proxy.ts

EXPOSE 8898

CMD ["node", "dist/v2-fork-lab/rpc_proxy.js"]
